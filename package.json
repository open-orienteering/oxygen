{
  "name": "oxygen",
  "version": "0.1.0",
  "private": true,
  "description": "Oxygen - Lightweight orienteering management",
  "scripts": {
    "dev": "pnpm --parallel --filter './packages/*' dev",
    "build": "pnpm --filter './packages/*' build",
    "lint": "pnpm --filter './packages/*' lint",
    "test": "pnpm --filter './packages/*' test",
    "test:coverage": "pnpm --filter './packages/*' test:coverage",
    "test:integration": "pnpm --filter @oxygen/api test:integration",
    "test:e2e": "playwright test",
    "db:generate": "pnpm --filter @oxygen/api db:generate",
    "db:push": "pnpm --filter @oxygen/api db:push",
    "docs:screenshots": "tsx docs/screenshots/capture.ts",
    "showcase:load": "bash scripts/load-showcase.sh"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "mysql2": "^3.17.0",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "i18next": "^26.0.8",
    "qrcode.react": "^4.2.0",
    "react-i18next": "^17.0.4",
    "svg-control-descriptions": "^2.1.0"
  },
  "pnpm": {
    "overrides": {
      "undici": "^7.24.5",
      "minimatch@<9.0.7": "^9.0.7",
      "flatted": "^3.4.2",
      "serialize-javascript": "^7.0.5",
      "effect": "^3.20.0",
      "postcss": "^8.5.10",
      "rollup@<4.59.0": "^4.59.0",
      "picomatch@<4.0.4": "^4.0.4",
      "defu": "^6.1.5",
      "vite@<7.3.2": "^7.3.2"
    }
  }
}
