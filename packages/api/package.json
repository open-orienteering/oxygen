{
  "name": "@oxygen/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "db:generate": "prisma generate",
    "db:pull": "prisma db pull",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@oxygen/shared": "workspace:*",
    "@prisma/client": "^6.19.2",
    "@resvg/resvg-js": "^2.6.2",
    "@trpc/server": "^11.10.0",
    "adm-zip": "^0.5.16",
    "dotenv": "^17.2.4",
    "fast-xml-parser": "^5.7.2",
    "fastify": "^5.8.5",
    "jsdom": "^29.0.2",
    "mysql2": "^3.17.0",
    "ocad2geojson": "github:marcus-kempe/ocad2geojson#v2.2.0-oxygen.0",
    "pino-pretty": "^13.1.3",
    "proj4": "^2.20.4",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.10.13",
    "@vitest/coverage-v8": "^4.0.18",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}